# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Gmail SMTP sending
# GMAIL_USER: your Gmail address (e.g. reshmis93@gmail.com)
# GMAIL_APP_PASSWORD: 16-char App Password from myaccount.google.com → Security → App passwords
#   (requires 2-Step Verification to be enabled on the Google account)
#   Omit both to run in print-only mode.
GMAIL_USER=reshmis93@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here
